{
  "name": "ji-hugo-theme",
  "version": "1.0.0",
  "description": "一个简洁现代的 Hugo 主题",
  "scripts": {
    "build": "echo 'This theme uses Hugo for building. Run: hugo --minify'",
    "dev": "hugo server -D",
    "serve": "hugo server -D --bind 0.0.0.0 --port 1313",
    "build:production": "hugo --minify --gc",
    "build:drafts": "hugo --minify --buildDrafts",
    "help": "echo 'Available commands: build, dev, serve, build:production, build:drafts'"
  },
  "keywords": [
    "hugo",
    "theme",
    "blog",
    "responsive",
    "dark-mode",
    "modern",
    "minimal",
    "fast",
    "accessible",
    "seo",
    "pwa",
    "chinese",
    "static-site",
    "jamstack"
  ],
  "author": {
    "name": "Jizuiba",
    "email": "jizuiba@example.com",
    "url": "https://github.com/jizuiba"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jizuiba/Ji.git"
  },
  "bugs": {
    "url": "https://github.com/jizuiba/Ji/issues"
  },
  "homepage": "https://github.com/jizuiba/Ji#readme",
  "engines": {
    "hugo": ">=0.149.1"
  },
  "files": [
    "assets/",
    "layouts/",
    "static/",
    "exampleSite/",
    "theme.toml",
    "README.md",
    "LICENSE"
  ],
  "hugo": {
    "min_version": "0.149.1",
    "extended": true
  },
  "theme": {
    "name": "Ji",
    "description": "一个简洁现代的 Hugo 主题",
    "tags": [
      "blog",
      "responsive",
      "dark-mode",
      "modern",
      "minimal"
    ],
    "features": [
      "responsive",
      "dark-mode",
      "syntax-highlighting",
      "search",
      "rss",
      "pwa",
      "accessibility"
    ]
  }
}
